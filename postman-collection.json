{
  "info": {
    "name": "Tarea 1 - Producto y Categoria (Postman)",
    "description": "Coleccion de pruebas para el CRUD de Producto y Categoria (Proyecto 3, Tarea 1). Coleccion de conveniencia para Postman; la entrega oficial del curso es insomnia-collection.json.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "super_admin_token", "value": "" },
    { "key": "user_token", "value": "" },
    { "key": "category_id", "value": "" },
    { "key": "product_id", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login Super Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('super_admin_token', body.token);",
                  "pm.test('login super admin ok', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"email\": \"superadmin@tarea1.com\",\n\t\"password\": \"SuperAdmin123!\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "Login User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const body = pm.response.json();",
                  "pm.collectionVariables.set('user_token', body.token);",
                  "pm.test('login user ok', function () { pm.response.to.have.status(200); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"email\": \"user@tarea1.com\",\n\t\"password\": \"User123!\"\n}"
            },
            "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Create Category (SUPER_ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('category_id', pm.response.json().data.id);",
                  "}",
                  "pm.test('created', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{super_admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"Electronica\",\n\t\"description\": \"Dispositivos y accesorios electronicos\"\n}"
            },
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "Create Category as USER (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('forbidden for USER', function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"No deberia crearse\",\n\t\"description\": \"Prueba de restriccion de rol\"\n}"
            },
            "url": { "raw": "{{base_url}}/categories", "host": ["{{base_url}}"], "path": ["categories"] }
          }
        },
        {
          "name": "List Categories (USER)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": {
              "raw": "{{base_url}}/categories?page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["categories"],
              "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }]
            }
          }
        },
        {
          "name": "Get Category by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{super_admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["categories", "{{category_id}}"]
            }
          }
        },
        {
          "name": "Update Category (SUPER_ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{super_admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"Electronica y Computo\",\n\t\"description\": \"Dispositivos, accesorios y equipo de computo\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["categories", "{{category_id}}"]
            }
          }
        },
        {
          "name": "Delete Category (SUPER_ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{super_admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/categories/{{category_id}}",
              "host": ["{{base_url}}"],
              "path": ["categories", "{{category_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Create Product (SUPER_ADMIN)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('product_id', pm.response.json().data.id);",
                  "}",
                  "pm.test('created', function () { pm.response.to.have.status(201); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{super_admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"Laptop Lenovo ThinkPad\",\n\t\"description\": \"Laptop empresarial 14 pulgadas\",\n\t\"price\": 850.50,\n\t\"stockQuantity\": 12,\n\t\"categoryId\": {{category_id}}\n}"
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "Create Product as USER (expect 403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('forbidden for USER', function () { pm.response.to.have.status(403); });"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{user_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"No deberia crearse\",\n\t\"description\": \"Prueba de restriccion de rol\",\n\t\"price\": 10.00,\n\t\"stockQuantity\": 1,\n\t\"categoryId\": {{category_id}}\n}"
            },
            "url": { "raw": "{{base_url}}/products", "host": ["{{base_url}}"], "path": ["products"] }
          }
        },
        {
          "name": "List Products (USER)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{user_token}}" }],
            "url": {
              "raw": "{{base_url}}/products?page=1&size=10",
              "host": ["{{base_url}}"],
              "path": ["products"],
              "query": [{ "key": "page", "value": "1" }, { "key": "size", "value": "10" }]
            }
          }
        },
        {
          "name": "Get Product by Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{super_admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Update Product (SUPER_ADMIN)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{super_admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"name\": \"Laptop Lenovo ThinkPad X1\",\n\t\"description\": \"Laptop empresarial 14 pulgadas, edicion actualizada\",\n\t\"price\": 899.99,\n\t\"stockQuantity\": 8,\n\t\"categoryId\": {{category_id}}\n}"
            },
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        },
        {
          "name": "Delete Product (SUPER_ADMIN)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{super_admin_token}}" }],
            "url": {
              "raw": "{{base_url}}/products/{{product_id}}",
              "host": ["{{base_url}}"],
              "path": ["products", "{{product_id}}"]
            }
          }
        }
      ]
    }
  ]
}
